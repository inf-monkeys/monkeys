            "key": "Authorization",
            "value": "Bearer {{bearerToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"page\": 1,\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tenant/outputs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tenant",
            "outputs"
          ]
        },
        "description": "测试基础的 tenant outputs 接口，验证新字段结构"
      }
    },
    {
      "name": "POST /api/tenant/outputs - searchableText 搜索",
      "request": {
        "method": "POST",

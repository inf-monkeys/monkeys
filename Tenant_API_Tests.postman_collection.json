        "description": "测试 extraMetadata 的数组查询功能（IN 查询）"
      }
    },
    {
      "name": "POST /api/tenant/outputs - 组合查询",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"page\": 1,\n  \"limit\": 5,\n  \"searchableText\": \"workflow\",\n  \"extraMetadata\": {\n    \"category\": [\"image\"]\n  }\n}"
